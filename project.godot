; Engine configuration file.
; Do not edit this file directly, unless you know what you are doing.

config_version=5

[application]

config/name="Tempest"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")

[autoload]

InputManager="*res://scripts/autoload/input_manager.gd"
GravityManager="*res://scripts/autoload/gravity_manager.gd"
TimeManager="*res://scripts/autoload/time_manager.gd"
LevelStateManager="*res://scripts/autoload/level_state_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
